<Window x:Class="АгентствоНедвижимости.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Агентство недвижимости &quot;Уютный Дом&quot;" 
        Height="700" Width="1000" 
        WindowStartupLocation="CenterScreen">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFE0F7FA" Offset="0"/>
            <GradientStop Color="#FFE8F5E9" Offset="0.5"/>
            <GradientStop Color="#FFF3E5F5" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Window.Resources>
    
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF45A049"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FF3E8E41"/>
                </Trigger>
            </Style.Triggers>
        </Style>

      
        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#FF2C3E50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="5,5,0,0" 
                                Padding="15,5"
                                Margin="2,0">
                            <ContentPresenter x:Name="ContentSite" 
                                              VerticalAlignment="Center" 
                                              HorizontalAlignment="Center"
                                              ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF1ABC9C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style TargetType="DataGrid">
            <Setter Property="AlternatingRowBackground" Value="#FFF2F2F2"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFBDC3C7"/>
            <Setter Property="RowHeight" Value="35"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

     
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="25"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#FFBDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,0"/>
        </Style>

    
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="25"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <TabControl>
      
            <TabItem Header="🏠 Объекты недвижимости">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button x:Name="btnОбновитьОбъекты" Content="Обновить список" 
                            Grid.Row="0" HorizontalAlignment="Left" Margin="0,0,0,10"
                            Click="btnОбновитьОбъекты_Click"/>
                    <DataGrid x:Name="dgОбъекты" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"/>
                </Grid>
            </TabItem>

            <TabItem Header="🔍 Подбор объектов">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="#FFF0F0F0" CornerRadius="10" Padding="10" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Критерии подбора" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                            <WrapPanel>
                                <Label>Тип:</Label>
                                <ComboBox x:Name="cmbТип" Width="120" Margin="0,0,15,0">
                                    <ComboBoxItem Content="Любой" IsSelected="True"/>
                                    <ComboBoxItem Content="Квартира"/>
                                    <ComboBoxItem Content="Дом"/>
                                    <ComboBoxItem Content="Офис"/>
                                </ComboBox>

                                <Label>Мин. площадь:</Label>
                                <TextBox x:Name="txtМинПлощадь" Width="80" Margin="0,0,15,0"/>

                                <Label>Макс. цена:</Label>
                                <TextBox x:Name="txtМаксЦена" Width="100" Margin="0,0,15,0"/>

                                <Label>Местоположение:</Label>
                                <TextBox x:Name="txtМестоположение" Width="120"/>
                            </WrapPanel>
                            <Button x:Name="btnПодобрать" Content="Подобрать" Width="150" HorizontalAlignment="Center" Margin="0,10,0,0" Click="btnПодобрать_Click"/>
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="dgПодбор" Grid.Row="2" AutoGenerateColumns="True" IsReadOnly="True"/>
                </Grid>
            </TabItem>

       
            <TabItem Header="👥 Клиенты">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="#FFF0F0F0" CornerRadius="10" Padding="10" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Добавление нового клиента" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                            <WrapPanel>
                                <Label>Фамилия:</Label>
                                <TextBox x:Name="txtФамилия" Width="100" Margin="0,0,15,0"/>
                                <Label>Имя:</Label>
                                <TextBox x:Name="txtИмя" Width="100" Margin="0,0,15,0"/>
                                <Label>Телефон:</Label>
                                <TextBox x:Name="txtТелефон" Width="120"/>
                            </WrapPanel>
                            <Button x:Name="btnДобавитьКлиента" Content="Добавить клиента" Width="150" HorizontalAlignment="Center" Margin="0,10,0,0" Click="btnДобавитьКлиента_Click"/>
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="dgКлиенты" Grid.Row="2" AutoGenerateColumns="True" IsReadOnly="True"/>
                </Grid>
            </TabItem>

            <!-- 3.4 Отчет по продажам -->
            <TabItem Header="📊 Продажи (отчет)">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button x:Name="btnСформироватьОтчет" Content="Сформировать отчет" 
                            HorizontalAlignment="Left" Margin="0,0,0,10"
                            Click="btnСформироватьОтчет_Click"/>
                    <DataGrid x:Name="dgОтчет" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"/>
                </Grid>
            </TabItem>

         
            <TabItem Header="📝 Заявки клиентов">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="btnОбновитьЗаявки" Content="Обновить заявки" Width="120" Click="btnОбновитьЗаявки_Click"/>
                        <Label Margin="20,0,5,0">Изменить статус:</Label>
                        <ComboBox x:Name="cmbНовыйСтатус" Width="100">
                            <ComboBoxItem Content="Активна" IsSelected="True"/>
                            <ComboBoxItem Content="Исполнена"/>
                            <ComboBoxItem Content="Отменена"/>
                        </ComboBox>
                        <Button x:Name="btnИзменитьСтатус" Content="Применить" Width="100" Click="btnИзменитьСтатус_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="dgЗаявки" Grid.Row="1" AutoGenerateColumns="True" 
                              IsReadOnly="True" SelectionChanged="dgЗаявки_SelectionChanged"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>